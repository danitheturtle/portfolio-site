---
import CarouselSlide from '@/components/CarouselSlide.astro';
import IntroSection from '@/components/intro-section/IntroSection.astro';
import MainLayout from '@/components/MainLayout.astro';

const slideCount = 7;
const slides = Array.from(Array(slideCount).keys());
---

<MainLayout>
  <div class='flex flex-col items-start justify-start px-8 lg:px-0'>
    <IntroSection />
    <h2 id='showcase' class='mt-4 mb-1'>Key Projects</h2>
    <div class='flex aspect-video w-full'>
      <carousel>
        {
          slides.map((i) => (
            <CarouselSlide carouselId='sc' index={i} slideCount={slideCount}>
              Slide {i}
            </CarouselSlide>
          ))
        }
      </carousel>
    </div>
  </div>
</MainLayout>
