---
import zeroTierShowcase from './zerotier-showcase.webp';
---

<style>
  .gradient {
    position: absolute;
    top: -1rem;
    left: -1rem;
    padding: 1rem;
    height: calc(100% + 2rem);
    width: calc(100% + 2rem);
    box-shadow: inset 0 0 8rem 2rem var(--color-on-surface);
  }
</style>
<img
  src={zeroTierShowcase.src}
  width={zeroTierShowcase.width}
  height={zeroTierShowcase.height}
  decoding='async'
  alt='ZeroTier video showcase'
  class='absolute'
/>
<div class='gradient flex items-center justify-center dark:shadow-none'>
  <div class='text-on-surface backdrop-blur-xs dark:text-surface'>
    <h3 class='p-6'>ZeroTier</h3>
  </div>
</div>
