---
import ThemeIcon from './svgs/Theme.astro';
import DownloadIcon from './svgs/Download.astro';
import PlusIcon from './svgs/Plus.astro';
import LinkIcon from './svgs/Link.astro';
import SendIcon from './svgs/Send.astro';
import QuoteIcon from './svgs/Quote.astro';
import CaretUpIcon from './svgs/CaretUp.astro';
import CaretRightIcon from './svgs/CaretRight.astro';
import CaretDownIcon from './svgs/CaretDown.astro';
import CircleLeftIcon from './svgs/CircleLeft.astro';
import CircleUpIcon from './svgs/CircleUp.astro';
import CircleRightIcon from './svgs/CircleRight.astro';
import CircleDownIcon from './svgs/CircleDown.astro';
import CaretLeftIcon from './svgs/CaretLeft.astro';

type IconType = (_props: Record<string, any>) => any;
// prettier-ignore
export type IconName = (
    'Theme'
  | 'Download'
  | 'Plus'
  | 'Link'
  | 'Send'
  | 'Quote'
  | 'CaretUp'
  | 'CaretRight'
  | 'CaretDown'
  | 'CaretLeft'
  | 'CircleUp'
  | 'CircleRight'
  | 'CircleDown'
  | 'CircleLeft'
);

export interface Props {
  icon: IconName;
  size?: string;
  class?: string;
}

const { icon, size = '1.5rem', class: classList = '' } = Astro.props as Props;

const iconNameToSvgComponentMap: Record<IconName, IconType> = {
  CaretDown: CaretDownIcon,
  CaretLeft: CaretLeftIcon,
  CaretRight: CaretRightIcon,
  CaretUp: CaretUpIcon,
  CircleDown: CircleDownIcon,
  CircleLeft: CircleLeftIcon,
  CircleRight: CircleRightIcon,
  CircleUp: CircleUpIcon,
  Download: DownloadIcon,
  Link: LinkIcon,
  Plus: PlusIcon,
  Quote: QuoteIcon,
  Send: SendIcon,
  Theme: ThemeIcon,
};

const IconComponent = iconNameToSvgComponentMap[icon];
---

<IconComponent width={size} height={size} class={classList} />
