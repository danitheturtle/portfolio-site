---
import Chip from '@/components/Chip.astro';
---

<h2 class='h2'>Chips</h2>
<div class='mt-4 flex flex-row flex-wrap items-start gap-2'>
  <Chip density='comfortable' size='lg'>Comfortable</Chip>
  <Chip size='lg'>Large</Chip>
  <Chip density='compact' size='lg'>Compact</Chip>
  <Chip density='comfortable'>Comfortable</Chip>
  <Chip>Default</Chip>
  <Chip density='compact'>Compact</Chip>
  <Chip density='comfortable' size='sm'>Comfortable</Chip>
  <Chip size='sm'>Small</Chip>
  <Chip density='compact' size='sm'>Compact</Chip>
</div>
<div class='mt-4 flex flex-row flex-wrap items-start gap-2'>
  <Chip density='comfortable' size='lg' color='border-secondary text-secondary'
    >Comfortable</Chip
  >
  <Chip size='lg' color='border-secondary text-secondary'>Large</Chip>
  <Chip density='compact' size='lg' color='border-secondary text-secondary'
    >Compact</Chip
  >
  <Chip density='comfortable' color='border-secondary text-secondary'
    >Comfortable</Chip
  >
  <Chip color='border-secondary text-secondary'>Default</Chip>
  <Chip density='compact' color='border-secondary text-secondary'>Compact</Chip>
  <Chip density='comfortable' size='sm' color='border-secondary text-secondary'
    >Comfortable</Chip
  >
  <Chip size='sm' color='border-secondary text-secondary'>Small</Chip>
  <Chip density='compact' size='sm' color='border-secondary text-secondary'
    >Compact</Chip
  >
</div>
