---
import CrownSlide from '@/components/carousel-slides/crown/CrownSlide.astro';
import KrogerSlide from '@/components/carousel-slides/kroger/KrogerSlide.astro';
import ZeroTierSlide from '@/components/carousel-slides/zerotier/ZeroTierSlide.astro';
import Carousel from '@/components/Carousel.astro';
import CarouselSlide from '@/components/CarouselSlide.astro';

const slideCount = 3;
---

<section id='showcase' class='order-3 mt-8 w-full'>
  <h2 class='h2'>Showcase</h2>
  <div class='mt-4 flex aspect-video w-full'>
    <Carousel>
      <CarouselSlide
        carouselId='sc'
        index={0}
        slideCount={slideCount}
        class='overflow-hidden bg-[#edcbbf]'
      >
        <ZeroTierSlide />
      </CarouselSlide>
      <CarouselSlide
        carouselId='sc'
        id='kroger-slide'
        lightControls={true}
        index={1}
        slideCount={slideCount}
      >
        <KrogerSlide />
      </CarouselSlide>
      <CarouselSlide carouselId='sc' index={2} slideCount={slideCount}>
        <CrownSlide />
      </CarouselSlide>
    </Carousel>
  </div>
</section>
