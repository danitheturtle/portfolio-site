---
import Icon from './icon/Icon.astro';

export interface Props {
  index: number;
  slideCount: number;
  carouselId?: string;
  active?: boolean;
  class?: string;
  [k: string]: any;
}
const {
  index,
  slideCount,
  carouselId = 'showcase',
  active = index === 0,
  class: className,
  ...rest
} = Astro.props as Props;

const prevIndex = index > 0 ? index - 1 : slideCount - 1;
const nextIndex = index < slideCount - 1 ? index + 1 : 0;
---

<label
  for={`${carouselId}-radio-${index}`}
  class:list={[
    'z-20 mb-4 inline-block h-4 w-4 cursor-pointer rounded-full border-2 border-grey-500 ring-grey-500 transition-colors',
    'hover:border-grey-700 active:bg-grey-700',
    'has-checked:border-grey-700 has-checked:bg-grey-700 has-checked:ring-1 has-checked:ring-grey-700',
    'has-focus-visible:ring-2 has-focus-visible:ring-focus',
    // tailwind is very stupid
    '[&:has(input:checked)+slide]:opacity-100',
  ]}
>
  <input
    checked={active}
    type='radio'
    name={carouselId}
    id={`${carouselId}-radio-${index}`}
    class='sr-only'
  />
</label>
<slide class='absolute h-full w-full opacity-0 transition-opacity duration-500'>
  <content class:list={['relative flex h-full w-full', className]} {...rest}>
    <slot />
  </content>
  <controls class='relative -top-1/2 z-20 flex w-full justify-between px-4'>
    <label class='cursor-pointer' for={`${carouselId}-radio-${prevIndex}`}>
      <Icon
        icon='CircleLeft'
        size='4rem'
        class='text-grey-500 hover:text-grey-700'
      />
      <span class='sr-only'>Previous Slide</span>
    </label>
    <label class='cursor-pointer' for={`${carouselId}-radio-${nextIndex}`}>
      <Icon
        icon='CircleRight'
        size='4rem'
        class='text-grey-500 hover:text-grey-700'
      />
      <span class='sr-only'>Next Slide</span>
    </label>
  </controls>
</slide>
