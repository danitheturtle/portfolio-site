---
import Icon from './icon/Icon.astro';

export interface Props {
  index: number;
  slideCount: number;
  carouselId?: string;
  active?: boolean;
  class?: string;
  lightControls?: boolean;
  [k: string]: any;
}
/*
  dark colors:
  normal: grey-700
  hover: grey-900

  light colors:
  normal: grey-50
  hover: grey-100
*/
const {
  index,
  slideCount,
  carouselId = 'showcase',
  lightControls = false,
  active = index === 0,
  class: className,
  ...rest
} = Astro.props as Props;

const prevIndex = index > 0 ? index - 1 : slideCount - 1;
const nextIndex = index < slideCount - 1 ? index + 1 : 0;
---

<label
  for={`${carouselId}-radio-${index}`}
  class:list={[
    'z-20 mb-5 inline-block h-6 w-6 cursor-pointer rounded-full border-3 border-(--carousel-controls-normal) ring-(--carousel-controls-normal) transition-colors',
    'hover:border-(--carousel-controls-hover) active:bg-(--carousel-controls-hover)',
    'has-checked:border-(--carousel-controls-hover) has-checked:bg-(--carousel-controls-hover) has-checked:ring-2 has-checked:ring-(--carousel-controls-hover)',
    'has-focus-visible:ring-3 has-focus-visible:ring-focus',
    // tailwind is very stupid
    '[&:has(input:checked)+slide]:opacity-100',
  ]}
>
  <input
    checked={active}
    type='radio'
    name={carouselId}
    id={`${carouselId}-radio-${index}`}
    class:list={['sr-only', { 'light-controls': lightControls }]}
  />
</label>
<slide class='absolute h-full w-full opacity-0 transition-opacity duration-500'>
  <content class:list={['relative flex h-full w-full', className]} {...rest}>
    <slot />
  </content>
  <controls
    class='relative top-[calc(-50%-3rem)] z-20 flex w-full justify-between px-4'
  >
    <label class='cursor-pointer' for={`${carouselId}-radio-${prevIndex}`}>
      <Icon
        icon='CircleLeft'
        size='6rem'
        class='text-(--carousel-controls-normal) transition-all hover:text-(--carousel-controls-hover)'
      />
      <span class='sr-only'>Previous Slide</span>
    </label>
    <label class='cursor-pointer' for={`${carouselId}-radio-${nextIndex}`}>
      <Icon
        icon='CircleRight'
        size='6rem'
        class='text-(--carousel-controls-normal) transition-all hover:text-(--carousel-controls-hover)'
      />
      <span class='sr-only'>Next Slide</span>
    </label>
  </controls>
</slide>
