---
import Icon from '@/components/icon/Icon.astro';
import type { IconName } from '@/components/icon/Icon.astro';

export interface Props {
  startIcon?: IconName;
  endIcon?: IconName;
  startIconSize?: string;
  endIconSize?: string;
  color?: string;
  hoverColor?: string;
  variant?: 'primary' | 'secondary' | 'text';
  size?: 'sm' | 'md' | 'lg';
  density?: 'compact' | 'normal' | 'comfortable';
  class?: string;
  as?: string;
  [k: string]: any;
}
const {
  as: Component = 'button',
  variant = 'secondary',
  size = 'md',
  density = 'normal',
  color = undefined,
  hoverColor = undefined,
  startIcon = undefined,
  endIcon = undefined,
  startIconSize = undefined,
  endIconSize = undefined,
  class: className,
  ...rest
} = Astro.props as Props;

let fIconSize = 1.0;
let iconSize = '1.0rem';
if (startIcon !== undefined || endIcon !== undefined) {
  if (density === 'compact') {
    fIconSize = 0.875;
  } else if (density === 'comfortable') {
    fIconSize = 1.125;
  }
  iconSize = `${fIconSize}rem`;
}

let style = '';
if (color !== undefined) {
  style += `--btn-color:var(--color-${color});`;
}
if (hoverColor !== undefined) {
  style += `--btn-color-lighten:var(--color-${hoverColor});`;
}
---

<Component
  class:list={[
    'btn',
    {
      'btn-primary': variant === 'primary',
      'btn-text': variant === 'text',
      'btn-sm': size === 'sm',
      'btn-lg': size === 'lg',
      'btn-compact': density === 'compact',
      'btn-comfortable': density === 'comfortable',
    },
    className,
  ]}
  {...style === '' ? {} : { style }}
  {...rest}
>
  {
    startIcon !== undefined && (
      <Icon
        icon={startIcon}
        class='start-icon'
        size={startIconSize === undefined ? iconSize : startIconSize}
      />
    )
  }
  <slot />
  {
    endIcon !== undefined && (
      <Icon
        icon={endIcon}
        class='end-icon'
        size={endIconSize === undefined ? iconSize : endIconSize}
      />
    )
  }
</Component>
