---
import Button from '@/components/Button.astro';
const buttonClasses =
  'rounded-none px-10 ' +
  'has-checked:border-primary-lighten has-checked:bg-primary-lighten has-checked:ring-primary-lighten ' +
  'has-focus-visible:z-30 has-focus-visible:ring-2 has-focus-visible:ring-secondary';
---

<style is:global>
  #theme-dropdown {
    position-area: bottom;
  }
</style>
<theme-selector
  aria-label='Choose your site theme'
  role='radiogroup'
  class='h-full'
>
  <Button
    id='theme-dropdown-button'
    popovertarget='theme-dropdown'
    variant='primary'
    startIcon='Theme'
  >
    Theme
  </Button>
  <dropdown
    popover
    id='theme-dropdown'
    anchor='theme-dropdown-button'
    class='overflow-visible bg-primary'
  >
    <div class='flex flex-col'>
      <Button
        as='label'
        for='auto-theme-radio'
        variant='primary'
        class={buttonClasses}
      >
        <input
          type='radio'
          name='theme-picker'
          id='auto-theme-radio'
          class='sr-only'
          checked
        />
        Auto
      </Button>
      <Button
        as='label'
        for='light-theme-radio'
        variant='primary'
        class={buttonClasses}
      >
        <input
          type='radio'
          name='theme-picker'
          id='light-theme-radio'
          class='sr-only'
        />
        Light
      </Button>
      <Button
        as='label'
        for='dark-theme-radio'
        variant='primary'
        class={buttonClasses}
      >
        <input
          type='radio'
          name='theme-picker'
          id='dark-theme-radio'
          class='sr-only'
        />
        Dark
      </Button>
      <Button
        as='label'
        for='rose-theme-radio'
        variant='primary'
        class={buttonClasses}
      >
        <input
          type='radio'
          name='theme-picker'
          id='rose-theme-radio'
          class='sr-only'
        />
        Rose
      </Button>
    </div>
  </dropdown>
</theme-selector>
