---
import Divider from './Divider.astro';
export interface Props {
  title?: string;
  subtitle?: string;
  divider?: boolean;
  density?: 'compact' | 'normal' | 'comfortable';
  class?: string;
  contentClass?: string;
  [k: string]: any;
}
const {
  title = '',
  subtitle = '',
  divider = false,
  density = 'normal',
  class: className,
  contentClass = '',
  ...rest
} = Astro.props as Props;
---

<div
  class:list={[
    'card',
    'flex flex-col',
    {
      'card-compact': density === 'compact',
      'card-comfortable': density === 'comfortable',
      'card-content': title == '',
      [contentClass]: title == '',
    },
    className,
  ]}
  {...rest}
>
  {
    title != '' && (
      <>
        <h2 class='text-5xl'>{title}</h2>
        {subtitle != '' && (
          <h3 class='text-xl font-normal text-text-lighten-1'>{subtitle}</h3>
        )}
        {divider && <Divider />}
        <div class:list={['card-content pt-1', contentClass]}>
          <slot />
        </div>
      </>
    )
  }
  {title == '' && <slot />}
</div>
