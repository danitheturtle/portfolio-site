---
export interface Props {
  class?: string;
  [k: string]: any;
}
const { class: className, ...rest } = Astro.props as Props;
---

<style>
  .carousel {
    &:not(:has(.light-controls:checked)) {
      --carousel-controls-normal: var(--color-grey-700);
      --carousel-controls-hover: var(--color-grey-900);
    }
    &:has(.light-controls:checked) {
      --carousel-controls-normal: var(--color-white);
      --carousel-controls-hover: var(--color-grey-300);
    }
  }
</style>
<carousel
  class:list={[
    'carousel',
    '@container/carousel',
    'relative flex flex-1 items-end justify-center gap-[4.69cqw] overflow-hidden bg-on-surface text-surface md:rounded-xl lg:gap-[1.56cqw]',
    className,
  ]}
  {...rest}
>
  <slot />
</carousel>
